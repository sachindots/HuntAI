# Copy to .env and fill. All free tiers — no paid keys.

# NVIDIA NIM (reasoning) — get free key at https://build.nvidia.com
HUNTAI_NVIDIA_API_KEY=

# Google Gemini (long-context / CAG) — free key at https://aistudio.google.com
HUNTAI_GEMINI_API_KEY=

# Ollama (local fallback + parsing + embeddings) — install: https://ollama.com
HUNTAI_OLLAMA_HOST=http://localhost:11434

# Force fully offline (Ollama-only), ignore cloud keys
HUNTAI_PREFER_OFFLINE=false

HUNTAI_SCOPE_FILE=scope.yaml
HUNTAI_DATA_DIR=./data

# ── Scope: hosts HuntAI is allowed to touch ──────────────────────────────
# Easiest way to change scope: list your authorized targets here, comma-separated.
# Accepts IPs, CIDRs, hostnames, or URLs. These are added to the lab defaults
# in scope.yaml. Only add targets you are authorized to test.
#   HUNTAI_ALLOWED_TARGETS="203.0.113.7, 10.0.0.0/24, app.example.com, https://demo.example.com"
HUNTAI_ALLOWED_TARGETS=
